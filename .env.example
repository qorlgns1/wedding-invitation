# Kakao JavaScript key (optional for Kakao share)
VITE_KAKAO_APP_KEY=your_kakao_javascript_key

# Optional: override production base path (default: /wedding-invitation/)
# VITE_BASE_PATH=/wedding-invitation/

# Optional: real account numbers for a private invitation build.
# Leave empty to keep portfolio-safe masked account display.
VITE_ACCOUNT_GROOM_FATHER=
VITE_ACCOUNT_GROOM_MOTHER=
VITE_ACCOUNT_GROOM=
VITE_ACCOUNT_BRIDE_FATHER=
VITE_ACCOUNT_BRIDE_MOTHER=
VITE_ACCOUNT_BRIDE=
